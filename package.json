{
    "name": "document-swiss-knife",
    "version": "1.0.0",
    "description": "Professional document management suite — Markdown to PDF with LaTeX-quality typography",
    "author": "Giuseppe <giuseppe@example.com>",
    "homepage": "https://github.com/giuseppe/document-swiss-knife",
    "main": "main.js",
    "scripts": {
        "start": "electron . --no-sandbox",
        "build": "electron-builder",
        "build:linux": "electron-builder --linux",
        "build:win": "electron-builder --win",
        "build:mac": "electron-builder --mac"
    },
    "dependencies": {
        "docx": "^9.5.3",
        "highlight.js": "^11.9.0",
        "katex": "^0.16.10",
        "marked": "^12.0.0",
        "marked-highlight": "^2.1.1",
        "mermaid": "^11.12.3",
        "monaco-editor": "^0.55.1",
        "pdf-lib": "^1.17.1",
        "turndown": "^7.2.4"
    },
    "devDependencies": {
        "electron": "^29.1.0",
        "electron-builder": "^24.13.3"
    },
    "build": {
        "appId": "com.dsk.document-swiss-knife",
        "productName": "Document Swiss Knife",
        "copyright": "Copyright © 2025 DSK",
        "asar": true,
        "directories": {
            "output": "dist"
        },
        "files": [
            "main.js",
            "preload.js",
            "renderer/**/*",
            "assets/**/*",
            "node_modules/**/*"
        ],
        "linux": {
            "target": [
                "AppImage",
                "deb"
            ],
            "category": "Office",
            "icon": "assets/icons"
        },
        "win": {
            "target": [
                {
                    "target": "nsis",
                    "arch": [
                        "x64"
                    ]
                }
            ],
            "icon": "assets/icons/icon.png"
        },
        "mac": {
            "target": [
                {
                    "target": "dmg",
                    "arch": [
                        "arm64",
                        "x64"
                    ]
                }
            ],
            "icon": "assets/icons/icon.png",
            "category": "public.app-category.productivity"
        },
        "nsis": {
            "oneClick": false,
            "allowToChangeInstallationDirectory": true
        }
    }
}
